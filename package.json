{
    "name": "factoryflow",
    "private": true,
    "workspaces": ["apps/*"],
    "scripts": {
        "dev:server": "npm run dev --workspace @factoryflow/server",
        "dev:factory-floor": "npm run dev --workspace @factoryflow/factory-floor",
        "dev": "concurrently -n server,factory -c cyan,green,magenta \"npm run dev --workspace @factoryflow/server\" \"npm run dev --workspace @factoryflow/factory-floor\""
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.2.2",
        "concurrently": "^9.2.1",
        "postcss": "^8.5.6",
        "prettier": "^3.5.3",
        "tailwindcss": "^4.1.5",
        "typescript": "^5.8.3"
    }
}
